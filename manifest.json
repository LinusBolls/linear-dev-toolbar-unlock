{
  "manifest_version": 3,
  "name": "Linear Dev Toolbar Unlock",
  "version": "1.0.0",
  "description": "Enables the Linear developer toolbar in your browser",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://linear.app/*"],
      "js": ["loader.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://linear.app/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "linear-dev-toolbar@local",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "64": "icon64.png",
    "96": "icon96.png",
    "128": "icon128.png"
  }
}
